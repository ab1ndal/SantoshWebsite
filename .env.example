# --- Phase 5: Sanity CMS ---
NEXT_PUBLIC_SANITY_PROJECT_ID=  # TODO: Create Sanity project at sanity.io, paste project ID here
SANITY_DATASET=production
SANITY_API_TOKEN=  # TODO: sanity.io -> API -> Tokens -> create read-only token

# --- Phase 5: Resend Email ---
RESEND_API_KEY=  # TODO: resend.com -> API Keys -> create key
FROM_EMAIL=  # TODO: Set to hello@[your-domain] after Resend domain verification
NOTIFY_EMAIL_PRIMARY=  # TODO: Primary notification recipient email
NOTIFY_EMAIL_CC=  # TODO: CC notification recipient email

# --- Phase 5: PostHog Analytics ---
NEXT_PUBLIC_POSTHOG_KEY=  # TODO: posthog.com -> Project Settings -> Project API Key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com  # or https://eu.i.posthog.com

# --- Phase 5: Site URL ---
NEXT_PUBLIC_BASE_URL=https://santosh-web.vercel.app  # TODO: Update when custom domain is purchased

# ============================================
# DEPLOYMENT CHECKLIST (Phase 5)
# ============================================
# 1. Create Sanity project: npx sanity@latest init (or sanity.io)
#    - Copy project ID to NEXT_PUBLIC_SANITY_PROJECT_ID
#    - Create API token at sanity.io -> API -> Tokens (read-only)
#    - Copy token to SANITY_API_TOKEN
#
# 2. Create Resend account: resend.com
#    - Create API key -> RESEND_API_KEY
#    - Add and verify sending domain -> set FROM_EMAIL
#    - Set NOTIFY_EMAIL_PRIMARY and NOTIFY_EMAIL_CC
#
# 3. Create PostHog account: posthog.com
#    - Create project -> copy API key to NEXT_PUBLIC_POSTHOG_KEY
#
# 4. Add all env vars to Vercel:
#    Vercel Dashboard -> Project -> Settings -> Environment Variables
#    Add each variable for Production + Preview environments
#
# 5. Enable Preview Deployments (D-20):
#    Vercel Dashboard -> Project -> Settings -> Git
#    Ensure "Preview Deployments" is enabled for all branches
#
# 6. Seed blog content:
#    - Visit /studio, log in with Sanity credentials
#    - Create 4 posts using content from SEED-CONTENT.md
#    - Set publishedAt date and generate slugs
#
# 7. Custom domain (when purchased):
#    - Vercel Dashboard -> Project -> Settings -> Domains -> Add
#    - Update DNS records per Vercel instructions
#    - Update NEXT_PUBLIC_BASE_URL to https://[your-domain]
# ============================================
